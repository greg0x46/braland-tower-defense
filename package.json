{
  "name": "br-td",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tower Defense Brasileiro - protótipo jogável",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit && vitest run",
    "generate:combat-sfx": "node tools/generate_combat_sfx.mjs",
    "prepare:sfx": "node tools/prepare_sfx.mjs",
    "adjust:sprite-sheet": "python3 tools/fix_sprite_sheet.py",
    "fix:sprite-sheet": "python3 tools/fix_sprite_sheet.py"
  },
  "dependencies": {
    "eventemitter3": "^5.0.4",
    "phaser": "^3.88.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
